# Anthropic: use a DEDICATED API key for this project (Console > API Keys),
# not your main key, so the spend cap below only affects this tool.
ANTHROPIC_API_KEY=

# Upstash Redis, free tier, create at upstash.com (choose "Redis", REST API enabled)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile, free, create at dash.cloudflare.com/?to=/:account/turnstile
# Use "Invisible" widget mode. The site key is public (goes in the frontend build),
# the secret key stays server-side only.
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Resend, free tier (3,000 emails/mo), create at resend.com
RESEND_API_KEY=
REPORT_FROM_EMAIL=
REPORT_TO_EMAIL=

# Set by you, checked by the cron endpoint to reject non-Vercel callers.
# Vercel auto-attaches this as a header on scheduled invocations once set as an env var.
CRON_SECRET=
